{
  "headers": [
    {
      "source": "/videos/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/videos/thumbnails/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "functions": {
    "src/app/api/resolve/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/hls/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/formats/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/channel/route.ts": {
      "maxDuration": 30
    }
  }
}